================================================================================
  WiiFin ← MPlayer CE integration patches
================================================================================
  These changes turn MPlayer CE into a static library (libmplayer.a) and add
  the hooks WiiFin uses for overlay rendering, seek/volume control, loading
  indicators, and clean shutdown.

  All patches are guarded by `#ifdef DISABLE_MAIN` so vanilla MPlayer CE
  builds are unaffected.

  The built library is copied to libs/mplayer-ce-build/libmplayer.a.
================================================================================

--- a/mplayer/mplayer.c
+++ b/mplayer/mplayer.c

 // --------------------------------------------------------------------------
 // Change 1: Include setjmp.h + extern for longjmp-based exit
 // --------------------------------------------------------------------------
 // After the standard includes (#include <assert.h>), add:
+#ifdef DISABLE_MAIN
+#include <setjmp.h>
+extern jmp_buf g_mplayer_jmp;  /* defined in WiiPlayer.cpp */
+#endif

 // --------------------------------------------------------------------------
 // Change 2: Replace exit(rc) with longjmp in exit_player_with_rc()
 // --------------------------------------------------------------------------
 // In exit_player_with_rc(), replace the exit(rc) call:
+#ifdef DISABLE_MAIN
+  longjmp(g_mplayer_jmp, rc == 0 ? 1 : rc);
+  __builtin_unreachable();
+#else
+  exit(rc);
+#endif

 // --------------------------------------------------------------------------
 // Change 3: Rename main() → mplayer_main(), add globals for WiiFin
 // --------------------------------------------------------------------------
 // Before the DISABLE_MAIN block with `int mplayer_main(...)`, add:
+#ifdef DISABLE_MAIN
+/* Callback invoked once, right after the stream URL is successfully opened.
+ * WiiFin uses this to send POST /Sessions/Playing after Jellyfin has started
+ * the transcode job (which begins when MPlayer first GETs the stream URL). */
+void (*g_stream_opened_cb)(void) = NULL;
+
+/* === WiiFin overlay integration ===
+ * These are DEFINED in WiiPlayer.cpp (same as g_mplayer_jmp);
+ * mplayer.c just reads/writes them as extern globals. */
+extern volatile float g_mplayer_time_pos;
+extern volatile float g_mplayer_duration;
+extern volatile int   g_mplayer_paused;
+extern volatile float g_wiifin_seek_secs;
+extern volatile int   g_wiifin_vol_delta;
+/* Duration from Jellyfin API (seconds); fallback when demuxer returns 0. */
+extern volatile float g_wiifin_known_duration;
+/* Loading-active flag; cleared here once playback progresses > 1 s. */
+extern volatile int   g_wiifin_loading_active;
+extern float g_wiifin_loading_start_pos;
+
+int mplayer_main(int argc,char* argv[]){
+#else
+int main(int argc,char* argv[]){
+#endif

 // --------------------------------------------------------------------------
 // Change 4: Stream-opened callback (after open_stream succeeds)
 // --------------------------------------------------------------------------
 // After `initialized_flags|=INITIALIZED_STREAM;`, add:
+#ifdef DISABLE_MAIN
+  /* Stream opened successfully — Jellyfin has now received the HTTP GET and
+   * is creating the transcode job.  Fire the one-shot callback (if set) so
+   * WiiFin can report playback start with PlayMethod=Transcode. */
+  if (g_stream_opened_cb) {
+    void (*cb)(void) = g_stream_opened_cb;
+    g_stream_opened_cb = NULL;  /* one-shot: clear before calling */
+    cb();
+  }
+#endif

 // --------------------------------------------------------------------------
 // Change 5: Main-loop hook — consume control requests, publish state,
 //           loading indicator logic, force loading frame
 // --------------------------------------------------------------------------
 // Insert BEFORE `if(rel_seek_secs || abs_seek_pos){`:
+#ifdef DISABLE_MAIN
+  if (g_wiifin_seek_secs >= 0.0f) {
+    rel_seek_secs      = g_wiifin_seek_secs;
+    abs_seek_pos       = SEEK_ABSOLUTE;
+    g_wiifin_seek_secs = -1.0f;
+  }
+  if (g_wiifin_vol_delta) {
+    int _vd = g_wiifin_vol_delta;
+    g_wiifin_vol_delta = 0;
+    if (_vd > 0) mixer_incvolume(&mpctx->mixer);
+    else         mixer_decvolume(&mpctx->mixer);
+  }
+  if (mpctx->sh_video)
+    g_mplayer_time_pos = (float)mpctx->sh_video->pts;
+  g_mplayer_duration = mpctx->demuxer
+    ? (float)demuxer_get_time_length(mpctx->demuxer) : 0.0f;
+  /* Fallback: use the duration fetched from Jellyfin when the MPEG-TS
+   * demuxer cannot determine it (common for live-transcoded streams).  */
+  if (g_mplayer_duration <= 0.5f && g_wiifin_known_duration > 0.5f)
+    g_mplayer_duration = g_wiifin_known_duration;
+  g_mplayer_paused = (mpctx->osd_function == OSD_PAUSE) ? 1 : 0;
+  /* Clear the loading indicator once playback has progressed > 1 s from
+   * the initial position.  For mid-stream resume (e.g. StartTimeTicks)
+   * the PTS starts at the seek target, so comparing against an absolute
+   * threshold of 1 s would clear the indicator immediately. */
+  if (g_wiifin_loading_active) {
+    if (g_wiifin_loading_start_pos < 0.0f && g_mplayer_time_pos > 0.0f)
+      g_wiifin_loading_start_pos = g_mplayer_time_pos;
+    /* Clear as soon as the first non-zero-PTS frame is decoded.
+     * Previously used (time_pos - start_pos) > 1.0f, but that caused a
+     * deadlock on mid-stream resume: start_pos was set to the resume PTS
+     * (e.g. 13.2 s), then needed time_pos > 14.2 s to clear.  Meanwhile
+     * mpgxForceLoadingFrame() was called every loop iteration, flooding
+     * the GX queue ("Too many buffered pts"), stalling video decode, and
+     * keeping time_pos frozen at 13.2 s forever.
+     * The 1500-iter fallback handles streams where PTS is always 0. */
+    if (g_wiifin_loading_start_pos >= 0.0f ||
+        loading_iter > 1500)
+      g_wiifin_loading_active = 0;
+    /* Force a frame push with the loading screen even when no video
+     * frame has been decoded yet (initial cache fill / post-seek
+     * buffering).  Without this, flip_page() is never called and
+     * the XFB shows purple / garbage data. */
+    else
+      mpgxForceLoadingFrame();
+  }
+#endif

--- a/mplayer/osdep/gx_supp.h
+++ b/mplayer/osdep/gx_supp.h

 // --------------------------------------------------------------------------
 // Change 6: Declare WiiFin overlay functions in gx_supp.h
 // --------------------------------------------------------------------------
 // After `void mpgxPushFrame();` add:
+
+/* WiiFin Y-texture overlay hook — set before calling mplayer_main(). */
+extern void (*g_wiifin_overlay_cb)(uint8_t *, int, int);
+void mpgxRunOverlay(void);
+void mpgxForceLoadingFrame(void);
+
+/* WiiFin GX overlay hook — registered by vo_gx.c preinit().
+ * Called inside mpgxPushFrame() between GX_CallDispList and GX_CopyDisp
+ * so the overlay is composited into the EFB with full colour + alpha. */
+extern void (*g_wiifin_gx_overlay_cb)(void);

--- a/mplayer/osdep/gx_supp.c
+++ b/mplayer/osdep/gx_supp.c

 // --------------------------------------------------------------------------
 // Change 7: mpgxInit() — debug logging + XFB allocation with black clear
 // --------------------------------------------------------------------------
 // At the start of mpgxInit():
+   SYS_Report("[gx_supp] mpgxInit() enter\n");
 //
 // In mpgxInit(), after GX init, allocate XFBs if NULL and clear to black:
+   if (!xfb[0]) {
+       xfb[0] = MEM_K0_TO_K1(SYS_AllocateFramebuffer(vmode));
+       VIDEO_ClearFrameBuffer(vmode, xfb[0], COLOR_BLACK);
+   }
+   if (!xfb[1]) {
+       xfb[1] = MEM_K0_TO_K1(SYS_AllocateFramebuffer(vmode));
+       VIDEO_ClearFrameBuffer(vmode, xfb[1], COLOR_BLACK);
+   }
 //
 // At the end of mpgxInit():
+   SYS_Report("[gx_supp] mpgxInit() done, xfb[0]=%p xfb[1]=%p\n", xfb[0], xfb[1]);

 // --------------------------------------------------------------------------
 // Change 8: mpgxConfigYUVp() — debug logging + clear textures to YCbCr black
 // --------------------------------------------------------------------------
 // At the start of mpgxConfigYUVp():
+   SYS_Report("[gx_supp] mpgxConfigYUVp(%u,%u,%u,%u)\n",
+              luma_width, luma_height, chroma_width, chroma_height);
 //
 // After Ytexture/Utexture/Vtexture allocation (both HW_RVL and non-RVL
 // paths), clear textures to proper YCbCr black:
+   memset(MEM_K1_TO_K0(Ytexture), 16, Ytexsize);    /* Y=16 → BT.601 black */
+   memset(MEM_K1_TO_K0(Utexture), 128, UVtexsize);  /* Cb=128 → neutral    */
+   memset(MEM_K1_TO_K0(Vtexture), 128, UVtexsize);  /* Cr=128 → neutral    */
+   DCFlushRange(MEM_K1_TO_K0(Ytexture), Ytexsize);
+   DCFlushRange(MEM_K1_TO_K0(Utexture), UVtexsize);
+   DCFlushRange(MEM_K1_TO_K0(Vtexture), UVtexsize);

 // --------------------------------------------------------------------------
 // Change 9: mpgxRunOverlay() + mpgxForceLoadingFrame()
 //           Insert BEFORE mpgxPushFrame()
 // --------------------------------------------------------------------------
+void (*g_wiifin_overlay_cb)(uint8_t *, int, int) = NULL;
+void (*g_wiifin_gx_overlay_cb)(void) = NULL;
+
+void mpgxRunOverlay(void)
+{
+    extern volatile int g_wiifin_loading_active;
+    if (!g_wiifin_overlay_cb || !Ytexture) return;
+
+    /* When loading, clear U and V textures to neutral (128) so the
+     * screen is truly black, not purple from stale decoded chroma. */
+    if (g_wiifin_loading_active) {
+        if (Utexture) {
+            uint8_t *U = (uint8_t *)MEM_K1_TO_K0(Utexture);
+            DCInvalidateRange(U, UVtexsize);
+            memset(U, 128, UVtexsize);
+            DCFlushRange(U, UVtexsize);
+        }
+        if (Vtexture) {
+            uint8_t *V = (uint8_t *)MEM_K1_TO_K0(Vtexture);
+            DCInvalidateRange(V, UVtexsize);
+            memset(V, 128, UVtexsize);
+            DCFlushRange(V, UVtexsize);
+        }
+    }
+
+    uint8_t *Y = (uint8_t *)MEM_K1_TO_K0(Ytexture);
+    DCInvalidateRange(Y, Ytexsize);
+    g_wiifin_overlay_cb(Y, (int)Ywidth, (int)Yheight);
+    DCFlushRange(Y, Ytexsize);
+}
+
+/* Force a loading frame to be rendered and pushed even when MPlayer has
+ * no decoded video frame yet (initial cache fill / post-seek buffering).
+ * Without this, flip_page() is never called and the XFB shows purple. */
+void mpgxForceLoadingFrame(void)
+{
+    extern volatile int g_wiifin_loading_active;
+    if (!g_wiifin_loading_active || !Ytexture || !g_wiifin_overlay_cb) return;
+    SYS_Report("[gx_supp] mpgxForceLoadingFrame() firing\n");
+    mpgxRunOverlay();
+    mpgxPushFrame();
+}

--- a/mplayer/libvo/vo_gx.c
+++ b/mplayer/libvo/vo_gx.c

 // --------------------------------------------------------------------------
 // Change 10: Call mpgxRunOverlay() in flip_page() before mpgxPushFrame()
 // --------------------------------------------------------------------------
 // In flip_page():
-        mpgxWaitDrawDone();
-        mpgxPushFrame();
+        mpgxWaitDrawDone();
+        mpgxRunOverlay();   /* WiiFin: draw progress bar into Y texture */
+        mpgxPushFrame();    /* renders video then fires gx_overlay via callback */

 // --------------------------------------------------------------------------
 // Change 11: Fix ov_gx_draw() — check loading_active BEFORE ov_visible
 // --------------------------------------------------------------------------
 // In ov_gx_draw(), the loading indicator panel must be checked before
 // the `if (!ov_visible) return;` guard.  ov_tick() returns early during
 // loading without setting ov_visible = 1, so the original order made the
 // loading panel branch unreachable.
 // Move the g_wiifin_loading_active block above the ov_visible check:
-        if (!ov_visible) return;
-
-        /* Loading indicator … */
-        if (g_wiifin_loading_active) { … }
+        /* Loading indicator — must come before ov_visible check because
+         * ov_tick() returns early during loading without setting ov_visible. */
+        if (g_wiifin_loading_active) {
+                f32 px0 = (f32)screenwidth * 0.28f;
+                f32 px1 = (f32)screenwidth * 0.72f;
+                ov_gx_enter_2d();
+                ov_rect(0.0f, 0.0f, (f32)screenwidth, 480.0f, 0, 0, 0, 120);
+                ov_rect(px0, 195.0f, px1, 285.0f, 8, 12, 30, 210);
+                ov_gx_leave_2d();
+                return;
+        }
+
+        if (!ov_visible) return;
